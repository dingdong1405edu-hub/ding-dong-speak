generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PracticeMode {
  PART_1
  PART_2
  PART_3
  MOCK_TEST
}

enum TransactionStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id             String            @id @default(uuid()) @db.Uuid
  name           String?
  email          String            @unique
  emailVerified  DateTime?
  image          String?
  isPro          Boolean           @default(false)
  premiumUntil   DateTime?
  credits        Int               @default(30)
  streak         Int               @default(0)
  lastActiveDate DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  accounts       Account[]
  sessions       Session[]
  practices      PracticeSession[]
  transactions   Transaction[]
  savedVocabs    SavedVocabulary[]
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PracticeSession {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  mode           PracticeMode
  promptText     String       @db.Text
  audioUrl       String?
  transcript     String       @db.Text
  overallScore   Int
  fluency        Int
  lexical        Int
  grammar        Int
  pronunciation  Int
  feedbackJson   Json
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([mode, createdAt])
}

model QuestionTopic {
  id        String         @id @default(uuid()) @db.Uuid
  part      PracticeMode
  name      String
  slug      String         @unique
  desc      String?
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  questions QuestionItem[]

  @@index([part, sortOrder])
}

model QuestionItem {
  id        String        @id @default(uuid()) @db.Uuid
  topicId    String       @db.Uuid
  part      PracticeMode
  promptText String       @db.Text
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  topic     QuestionTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId, sortOrder])
  @@index([part, createdAt])
}

model SavedVocabulary {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  phrase    String
  mode      PracticeMode?
  source    String?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phrase])
  @@index([userId, createdAt])
}

model Transaction {
  id           String            @id @default(uuid()) @db.Uuid
  userId        String            @db.Uuid
  amount        Int
  packageId     String
  durationMonths Int               @default(1)
  status        TransactionStatus @default(PENDING)
  orderCode     String            @unique
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
